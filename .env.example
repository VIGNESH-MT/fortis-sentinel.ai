# FORTIS SENTINEL Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=fortis-sentinel
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (PostgreSQL for production, SQLite for development)
DATABASE_URL=sqlite:///./fortis_sentinel.db
# DATABASE_URL=postgresql://fortis:fortis_password@localhost:5432/fortis_sentinel

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Encryption
ENCRYPTION_KEY=change-this-to-a-32-byte-key-in-production

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Celery
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
